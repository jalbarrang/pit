#!/usr/bin/env bash
set -euo pipefail
need_major=26
need_minor=4
version=$(node -p 'process.versions.node' 2>/dev/null || true)
if [ -z "$version" ]; then
  echo "pit requires Node >=26.4.0 on PATH" >&2
  exit 1
fi
major=${version%%.*}
rest=${version#*.}
minor=${rest%%.*}
if [ "$major" -lt "$need_major" ] || { [ "$major" -eq "$need_major" ] && [ "$minor" -lt "$need_minor" ]; }; then
  echo "pit requires Node >=26.4.0; found $version" >&2
  exit 1
fi
source_path=${BASH_SOURCE[0]}
while [ -L "$source_path" ]; do
  dir=$(cd -P "$(dirname "$source_path")" && pwd)
  target=$(readlink "$source_path")
  case "$target" in
    /*) source_path=$target ;;
    *) source_path=$dir/$target ;;
  esac
done
root=$(cd -P "$(dirname "$source_path")/.." && pwd)
exec node --experimental-ffi "$root/src/main.ts" "$@"
